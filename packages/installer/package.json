{
  "name": "ccusage-worv",
  "version": "0.1.0",
  "description": "Claude Code 팀 사용량 자동 수집 플러그인 설치 도구",
  "type": "module",
  "bin": {
    "ccusage-worv": "./bin/install.mjs"
  },
  "files": [
    "bin/",
    "plugin/"
  ],
  "scripts": {
    "prepack": "node -e \"const{cpSync,rmSync,existsSync}=require('fs');if(existsSync('plugin'))rmSync('plugin',{recursive:true});cpSync('../../plugin','plugin',{recursive:true})\""
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/inkeunseo-maum/ccusage-worv"
  },
  "license": "MIT"
}
